# Undo "export MSYS=winsymlinks" done in top-level Makefile
unset MSYS

cd src

# On MSYS2,
# configure_file(... COPYONLY) somehow leads to the creation of unusable Windows .lnk files
sed -i.bak 's/COPYONLY//' CMakeLists.txt

if [ -n $MSYSTEM ]; then
    sdh_cmake -G Ninja \
        -DENABLE_ARCH=NO \
        .
    cmake --build .
    DESTDIR=$SAGE_DESTDIR cmake --install .
else
    sdh_make_install
fi
