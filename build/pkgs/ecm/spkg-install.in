# Needed because of primesieve
if [ "$UNAME" = "Darwin" ]; then
    LDFLAGS="${LDFLAGS} -Wl,-rpath,${SAGE_LOCAL}/lib"
    export LDFLAGS
fi

cd src/

# Use newer version of config.guess and config.sub (see Issue #19724)
cp "$SAGE_ROOT"/config/config.* .

sdh_configure $SAGE_CONFIGURE_GMP --disable-static --enable-shared
sdh_make
sdh_make_install
